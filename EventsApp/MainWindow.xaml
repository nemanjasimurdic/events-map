<Window x:Class="EventsApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:EventsApp.ViewModel"
        mc:Ignorable="d"
        Title="EventMapApp" Height="768" Width="1024" ResizeMode="NoResize">

    <Window.DataContext>
        <vm:MainWindowViewModel/>
    </Window.DataContext>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="1"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ── HEADER ── -->
        <Grid Grid.Row="0">
            <Button x:Name="HamburgerButton" Click="HamburgerButton_Click"
                    Background="Transparent" BorderThickness="0"
                    HorizontalAlignment="Left" VerticalAlignment="Center"
                    Margin="15,0,0,0" Width="36" Height="36" Padding="6">
                <Image Source="/Resources/Images/hamburger-menu.png" Stretch="Uniform"/>
            </Button>

            <TextBlock Text="Event map" FontSize="22" FontWeight="Bold"
                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Grid>

        <!-- Popup lives at root Grid level so the 60px header row cannot clip it -->
        <Popup x:Name="HamburgerPopup" Grid.Row="0"
               PlacementTarget="{Binding ElementName=HamburgerButton}"
               Placement="Bottom" StaysOpen="False">
            <Border Background="White" BorderBrush="Black" BorderThickness="1" MinWidth="210">
                <StackPanel>
                    <Button Click="MenuEvents_Click" Background="Transparent" BorderThickness="0"
                            HorizontalContentAlignment="Left" Padding="14,10">
                        <StackPanel Orientation="Horizontal">
                            <Image Source="/Resources/Images/event.png" Width="18" Height="18" VerticalAlignment="Center"/>
                            <TextBlock Text="Events" Margin="10,0,0,0" VerticalAlignment="Center"
                                       FontSize="14" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Button>
                    <Button Click="MenuEventTypes_Click" Background="Transparent" BorderThickness="0"
                            HorizontalContentAlignment="Left" Padding="14,10">
                        <StackPanel Orientation="Horizontal">
                            <Image Source="/Resources/Images/event-type.png" Width="18" Height="18" VerticalAlignment="Center"/>
                            <TextBlock Text="Event types" Margin="10,0,0,0" VerticalAlignment="Center"
                                       FontSize="14" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Button>
                    <Button Click="MenuTags_Click" Background="Transparent" BorderThickness="0"
                            HorizontalContentAlignment="Left" Padding="14,10">
                        <StackPanel Orientation="Horizontal">
                            <Image Source="/Resources/Images/tag.png" Width="18" Height="18" VerticalAlignment="Center"/>
                            <TextBlock Text="Tags" Margin="10,0,0,0" VerticalAlignment="Center"
                                       FontSize="14" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Button>
                    <Button Click="MenuStatistics_Click" Background="Transparent" BorderThickness="0"
                            HorizontalContentAlignment="Left" Padding="14,10">
                        <StackPanel Orientation="Horizontal">
                            <Image Source="/Resources/Images/statistic.png" Width="18" Height="18" VerticalAlignment="Center"/>
                            <TextBlock Text="Statistics" Margin="10,0,0,0" VerticalAlignment="Center"
                                       FontSize="14" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Border>
        </Popup>

        <Rectangle Grid.Row="1" Fill="Black"/>

        <!-- ── MAIN CONTENT ── -->
        <Grid Grid.Row="2">

            <!-- Map Workspace: default view, visible on startup -->
            <Grid x:Name="MapWorkspace">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="280"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- LEFT COLUMN: scrollable events list -->
                <Grid Grid.Column="0" Margin="20,10,0,20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Events" FontSize="15" FontWeight="Bold"
                               Margin="0,0,0,10"/>

                    <Border Grid.Row="1" x:Name="ListBorder"
                            BorderBrush="Black" BorderThickness="1" Padding="10"
                            AllowDrop="True"
                            DragOver="ListBorder_DragOver"
                            Drop="ListBorder_Drop"
                            PreviewMouseLeftButtonDown="ListBorder_PreviewMouseLeftButtonDown"
                            PreviewMouseLeftButtonUp="ListBorder_PreviewMouseLeftButtonUp"
                            PreviewMouseMove="ListBorder_PreviewMouseMove">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding EventItems}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="Black" BorderThickness="1" CornerRadius="6"
                                            Margin="0,0,0,20" Padding="10">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="56"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>

                                            <Image Grid.Column="0"
                                                   Source="{Binding IconPath}"
                                                   Width="48" Height="48"
                                                   VerticalAlignment="Top"
                                                   Stretch="Uniform"/>

                                            <StackPanel Grid.Column="1" Margin="10,0,0,0">
                                                <TextBlock Text="{Binding Name}"
                                                           FontWeight="Bold" FontSize="13"
                                                           TextWrapping="Wrap"/>

                                                <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                                                    <Image Source="/Resources/Images/location.png"
                                                           Width="13" Height="13"
                                                           VerticalAlignment="Center"/>
                                                    <TextBlock Text="{Binding Location}"
                                                               FontSize="11" Margin="4,0,0,0"
                                                               VerticalAlignment="Center"/>
                                                </StackPanel>

                                                <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                                                    <Image Source="/Resources/Images/date.png"
                                                           Width="13" Height="13"
                                                           VerticalAlignment="Center"/>
                                                    <TextBlock Text="{Binding DateText}"
                                                               FontSize="11" Margin="4,0,0,0"
                                                               VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        </ScrollViewer>
                    </Border>
                </Grid>

                <!-- RIGHT COLUMN: filter row + map -->
                <Grid Grid.Column="1" Margin="20,10,20,20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- FILTER ROW -->
                    <StackPanel Grid.Row="0" Orientation="Horizontal"
                                Margin="0,0,0,10" VerticalAlignment="Center">

                        <TextBlock Text="Filter events:" FontSize="13"
                                   VerticalAlignment="Center" Margin="0,0,8,0"/>

                        <Grid Width="220">
                            <TextBox x:Name="FilterBox" Padding="5,4" FontSize="12"
                                     Text="{Binding MapFilterText, UpdateSourceTrigger=PropertyChanged}"/>
                            <TextBlock Text="Filter events by name" Foreground="Gray"
                                       FontSize="12" IsHitTestVisible="False"
                                       Margin="7,0,0,0" VerticalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Text, ElementName=FilterBox}" Value="">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>

                        <Button Margin="8,0,0,0" Padding="7,4" Click="ResetButton_Click">
                            <StackPanel Orientation="Horizontal">
                                <Image Source="/Resources/Images/reset.png"
                                       Width="14" Height="14" VerticalAlignment="Center"/>
                                <TextBlock Text="Reset" FontSize="12"
                                           Margin="4,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>

                    <!-- MAP AREA -->
                    <Grid Grid.Row="1">
                        <Image Source="/Resources/Images/world-map.png" Stretch="Uniform"/>
                        <Canvas x:Name="MapCanvas" Background="Transparent"
                                AllowDrop="True"
                                DragOver="MapCanvas_DragOver"
                                Drop="MapCanvas_Drop"/>
                    </Grid>
                </Grid>
            </Grid>

            <!-- Navigation frame: hidden by default, shown when a menu page is active -->
            <Frame x:Name="MainFrame" NavigationUIVisibility="Hidden"
                   Visibility="Collapsed" Background="White"/>
        </Grid>
    </Grid>
</Window>
