<Window x:Class="EventsApp.View.SearchEventTypeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Search Event Types"
        Width="420" Height="360"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="52"/>
            <RowDefinition Height="1"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="1"/>
            <RowDefinition Height="52"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal"
                    VerticalAlignment="Center" Margin="16,0">
            <Image Source="/Resources/Images/back.png"
                   Width="20" Height="20" VerticalAlignment="Center"/>
            <TextBlock Text="Search event types" FontSize="15" FontWeight="SemiBold"
                       VerticalAlignment="Center" Margin="10,0,0,0"/>
        </StackPanel>

        <Rectangle Grid.Row="1" Fill="#E0E0E0"/>

        <StackPanel Grid.Row="2" Margin="16,20,16,20">

            <TextBlock Text="Name:" FontSize="12" FontWeight="SemiBold"
                       Margin="0,0,0,3"/>
            <TextBox Text="{Binding Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     Padding="5,4" FontSize="12" Margin="0,0,0,10"/>

            <TextBlock Text="Description:" FontSize="12" FontWeight="SemiBold"
                       Margin="0,0,0,3"/>
            <TextBox Text="{Binding Description, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     Padding="5,4" FontSize="12" Height="72"
                     AcceptsReturn="True" TextWrapping="Wrap"
                     VerticalScrollBarVisibility="Auto"
                     VerticalContentAlignment="Top"/>

        </StackPanel>

        <Rectangle Grid.Row="3" Fill="#E0E0E0"/>

        <StackPanel Grid.Row="4" Orientation="Horizontal"
                    HorizontalAlignment="Right" VerticalAlignment="Center"
                    Margin="0,0,16,0">
            <Button Padding="12,6" Margin="0,0,20,0" Click="SearchButton_Click">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <Image Source="/Resources/Images/yes.png"
                           Width="14" Height="14" VerticalAlignment="Center"/>
                    <TextBlock Text="Search" FontSize="12"
                               Margin="6,0,0,0" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
            <Button Padding="12,6" Margin="0,0,20,0" Click="ResetButton_Click">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <Image Source="/Resources/Images/reset.png"
                           Width="14" Height="14" VerticalAlignment="Center"/>
                    <TextBlock Text="Reset" FontSize="12"
                               Margin="6,0,0,0" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
            <Button Padding="12,6" Click="CloseButton_Click">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <Image Source="/Resources/Images/close.png"
                           Width="14" Height="14" VerticalAlignment="Center"/>
                    <TextBlock Text="Close" FontSize="12"
                               Margin="6,0,0,0" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
        </StackPanel>

    </Grid>
</Window>
