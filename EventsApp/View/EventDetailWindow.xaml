<Window x:Class="EventsApp.View.EventDetailWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Event details"
        Width="580" Height="550"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="52"/>
            <RowDefinition Height="1"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="1"/>
            <RowDefinition Height="52"/>
        </Grid.RowDefinitions>


        <StackPanel Grid.Row="0" Orientation="Horizontal"
                    VerticalAlignment="Center" Margin="16,0">
            <Image Source="/Resources/Images/back.png"
                   Width="20" Height="20" VerticalAlignment="Center"/>
            <TextBlock Text="Event details" FontSize="15" FontWeight="SemiBold"
                       VerticalAlignment="Center" Margin="10,0,0,0"/>
        </StackPanel>

        <Rectangle Grid.Row="1" Fill="#E0E0E0"/>

        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="24,20,24,20">

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="1.5*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">

                        <Image Source="{Binding IconPath}"
                               Width="56" Height="56" Stretch="Uniform"
                               HorizontalAlignment="Left"/>

                        <TextBlock Text="{Binding Name}"
                                   FontSize="18" FontWeight="Bold"
                                   TextWrapping="Wrap" Margin="0,12,0,0"/>

                        <TextBlock Text="{Binding EventId, StringFormat='Event \#{0}'}"
                                   FontSize="11" Foreground="#888888" Margin="0,4,0,0"/>

                        <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                            <Image Source="{Binding TypeIconPath}"
                                   Width="16" Height="16" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding TypeName}" FontSize="12"
                                       Margin="7,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>

                        <Rectangle Height="1" Fill="#E8E8E8" Margin="0,14,0,14"/>

                        <TextBlock Text="{Binding Description}"
                                   FontSize="12" TextWrapping="Wrap"
                                   LineHeight="19" Foreground="#333333"/>
                    </StackPanel>


                    <StackPanel Grid.Column="2">

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <Image Source="/Resources/Images/location.png"
                                   Width="13" Height="13" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding Location}" FontSize="12"
                                       Margin="7,0,0,0" VerticalAlignment="Center"
                                       TextWrapping="Wrap"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <Image Source="/Resources/Images/date.png"
                                   Width="13" Height="13" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding CurrentDateText}" FontSize="12"
                                       Margin="7,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <Image Source="/Resources/Images/audience.png"
                                   Width="16" Height="16" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding AttendanceText}" FontSize="12"
                                       Margin="7,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <Image Source="/Resources/Images/dollar.png"
                                   Width="14" Height="14" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding AverageCostText}" FontSize="12"
                                       Margin="7,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>

                        <TextBlock FontSize="12" Margin="0,0,0,16">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="✓ Humanitarian event"/>
                                    <Setter Property="Foreground" Value="#333333"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsHumanitarian}" Value="False">
                                            <Setter Property="Text" Value="Not humanitarian"/>
                                            <Setter Property="Foreground" Value="#AAAAAA"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                        <Rectangle Height="1" Fill="#E8E8E8" Margin="0,0,0,12"/>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <Image Source="/Resources/Images/date.png"
                                   Width="13" Height="13" VerticalAlignment="Center"/>
                            <TextBlock Text="Past dates" FontSize="12" FontWeight="SemiBold"
                                       Margin="7,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>

                        <ScrollViewer MaxHeight="130" VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding HistoryDateTexts}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}" FontSize="11"
                                                   Foreground="#555555" Margin="0,2"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>

                    </StackPanel>
                </Grid>

                <StackPanel Margin="0,20,0,0">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <Image Source="/Resources/Images/tag.png"
                               Width="13" Height="13" VerticalAlignment="Center"/>
                        <TextBlock Text="Tags" FontSize="12" FontWeight="SemiBold"
                                   Margin="7,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>
                    <ItemsControl ItemsSource="{Binding Tags}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="#BBBBBB" BorderThickness="1"
                                        CornerRadius="10" Padding="10,4" Margin="0,0,6,4">
                                    <TextBlock Text="{Binding Label}" FontSize="11"/>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

            </StackPanel>
        </ScrollViewer>

        <Rectangle Grid.Row="3" Fill="#E0E0E0"/>


        <Grid Grid.Row="4">
            <Button HorizontalAlignment="Right" VerticalAlignment="Center"
                    Margin="0,0,16,0" Padding="12,6"
                    Click="CloseButton_Click">
                <StackPanel Orientation="Horizontal">
                    <Image Source="/Resources/Images/close.png"
                           Width="14" Height="14" VerticalAlignment="Center"/>
                    <TextBlock Text="Close" FontSize="12"
                               Margin="6,0,0,0" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
        </Grid>
    </Grid>
</Window>
