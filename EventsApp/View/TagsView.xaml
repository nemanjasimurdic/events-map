<Page x:Class="EventsApp.Pages.TagsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Tags"
      Background="White">

    <Grid Margin="20,10,20,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="48"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ── ACTION ROW ── -->
        <Grid Grid.Row="1">

            <!-- Left: Add tag + Search -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left"
                        VerticalAlignment="Center">
                <Button Padding="7,4" Margin="0,0,8,0" Click="AddTag_Click">
                    <StackPanel Orientation="Horizontal">
                        <Image Source="/Resources/Images/add.png"
                               Width="14" Height="14" VerticalAlignment="Center"/>
                        <TextBlock Text="Add tag" FontSize="12"
                                   Margin="4,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button Padding="7,4" Click="SearchButton_Click">
                    <StackPanel Orientation="Horizontal">
                        <Image Source="/Resources/Images/search.png"
                               Width="14" Height="14" VerticalAlignment="Center"/>
                        <TextBlock Text="Search" FontSize="12"
                                   Margin="4,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </StackPanel>

            <!-- Right: Filter label + TextBox + Reset -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                        VerticalAlignment="Center">
                <TextBlock Text="Filter tags:" FontSize="13"
                           VerticalAlignment="Center" Margin="0,0,8,0"/>
                <Grid Width="200">
                    <TextBox x:Name="FilterBox" Padding="5,4" FontSize="12"/>
                    <TextBlock Text="Filter tags" Foreground="Gray" FontSize="12"
                               IsHitTestVisible="False" Margin="7,0,0,0"
                               VerticalAlignment="Center">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Text, ElementName=FilterBox}"
                                                 Value="">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>
                <Button Padding="7,4" Margin="8,0,0,0" Click="ResetFilter_Click">
                    <StackPanel Orientation="Horizontal">
                        <Image Source="/Resources/Images/reset.png"
                               Width="14" Height="14" VerticalAlignment="Center"/>
                        <TextBlock Text="Reset" FontSize="12"
                                   Margin="4,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>

        <!-- ── DATA GRID ── -->
        <DataGrid Grid.Row="3"
                  ItemsSource="{Binding Tags}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  SelectionMode="Single"
                  RowHeight="52"
                  GridLinesVisibility="Horizontal"
                  HorizontalGridLinesBrush="#E0E0E0"
                  HeadersVisibility="Column"
                  BorderThickness="1"
                  BorderBrush="#CCCCCC">

            <DataGrid.ColumnHeaderStyle>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="Padding" Value="6,4"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                    <Setter Property="FontSize" Value="12"/>
                    <Setter Property="Background" Value="#F5F5F5"/>
                    <Setter Property="BorderBrush" Value="#CCCCCC"/>
                    <Setter Property="BorderThickness" Value="0,0,0,1"/>
                </Style>
            </DataGrid.ColumnHeaderStyle>

            <DataGrid.CellStyle>
                <Style TargetType="DataGridCell">
                    <Setter Property="Padding" Value="6,0"/>
                    <Setter Property="VerticalContentAlignment" Value="Center"/>
                    <Setter Property="BorderThickness" Value="0"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="DataGridCell">
                                <Border Padding="{TemplateBinding Padding}"
                                        Background="{TemplateBinding Background}">
                                    <ContentPresenter VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </DataGrid.CellStyle>

            <DataGrid.Columns>

                <!-- ID -->
                <DataGridTextColumn Header="ID" Binding="{Binding Code}" Width="1*">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="VerticalAlignment" Value="Center"/>
                            <Setter Property="FontSize" Value="12"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <!-- Color -->
                <DataGridTextColumn Header="Color" Binding="{Binding ColorDisplay}" Width="3*">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="VerticalAlignment" Value="Center"/>
                            <Setter Property="FontSize" Value="12"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <!-- Actions -->
                <DataGridTemplateColumn Header="Actions" Width="2*" IsReadOnly="True">
                    <DataGridTemplateColumn.HeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Padding" Value="6,4"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="FontSize" Value="12"/>
                            <Setter Property="Background" Value="#F5F5F5"/>
                            <Setter Property="BorderBrush" Value="#CCCCCC"/>
                            <Setter Property="BorderThickness" Value="0,0,0,1"/>
                            <Setter Property="HorizontalContentAlignment" Value="Center"/>
                        </Style>
                    </DataGridTemplateColumn.HeaderStyle>
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center">
                                <Button Background="Transparent" BorderThickness="0"
                                        Padding="8" ToolTip="Info"
                                        Click="InfoButton_Click">
                                    <Image Source="/Resources/Images/info.png"
                                           Width="24" Height="24"/>
                                </Button>
                                <Button Background="Transparent" BorderThickness="0"
                                        Padding="8" Margin="8,0,0,0"
                                        Click="EditButton_Click">
                                    <Image Source="/Resources/Images/edit.png"
                                           Width="24" Height="24"/>
                                </Button>
                                <Button Background="Transparent" BorderThickness="0"
                                        Padding="8" Margin="8,0,0,0"
                                        Click="DeleteButton_Click">
                                    <Image Source="/Resources/Images/delete.png"
                                           Width="24" Height="24"/>
                                </Button>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Page>
