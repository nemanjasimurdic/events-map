<Window x:Class="EventsApp.View.AddEventTypeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Add Event Type"
        Width="460" Height="500"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="52"/>
            <RowDefinition Height="1"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="1"/>
            <RowDefinition Height="52"/>
        </Grid.RowDefinitions>


        <StackPanel Grid.Row="0" Orientation="Horizontal"
                    VerticalAlignment="Center" Margin="16,0">
            <Image Source="/Resources/Images/back.png"
                   Width="20" Height="20" VerticalAlignment="Center"/>
            <TextBlock Text="Add Event Type Form" FontSize="15" FontWeight="SemiBold"
                       VerticalAlignment="Center" Margin="10,0,0,0"/>
        </StackPanel>

        <Rectangle Grid.Row="1" Fill="#E0E0E0"/>

        
        <StackPanel Grid.Row="2" Margin="16,20,16,20">

            <TextBlock Text="Icon:" FontSize="12" FontWeight="SemiBold"
                       Margin="0,0,0,3"/>
            <StackPanel Margin="0,0,0,10">
                <StackPanel Orientation="Horizontal">
                    <ComboBox ItemsSource="{Binding IconItems}"
                              SelectedItem="{Binding SelectedIcon, Mode=TwoWay, ValidatesOnNotifyDataErrors=False}"
                              DisplayMemberPath="DisplayName"
                              Width="170" Padding="5,3" FontSize="12"/>
                    <Image Source="{Binding IconPreviewPath}"
                           Width="28" Height="28" Stretch="Uniform"
                           Margin="10,0,0,0" VerticalAlignment="Center"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal"
                            Visibility="{Binding IconHasError, Converter={StaticResource BoolToVis}}"
                            Margin="0,3,0,0">
                    <TextBlock Text="! " FontWeight="Bold" FontSize="11"/>
                    <TextBlock Text="{Binding IconError}" FontSize="11"/>
                </StackPanel>
            </StackPanel>

            <TextBlock Text="ID:" FontSize="12" FontWeight="SemiBold"
                       Margin="0,0,0,3"/>
            <StackPanel Margin="0,0,0,10">
                <TextBox Text="{Binding IdText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=False}"
                         Padding="5,4" FontSize="12"/>
                <StackPanel Orientation="Horizontal"
                            Visibility="{Binding IdHasError, Converter={StaticResource BoolToVis}}"
                            Margin="0,3,0,0">
                    <TextBlock Text="! " FontWeight="Bold" FontSize="11"/>
                    <TextBlock Text="{Binding IdError}" FontSize="11"/>
                </StackPanel>
            </StackPanel>

            <TextBlock Text="Name:" FontSize="12" FontWeight="SemiBold"
                       Margin="0,0,0,3"/>
            <StackPanel Margin="0,0,0,10">
                <TextBox Text="{Binding Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=False}"
                         Padding="5,4" FontSize="12"/>
                <StackPanel Orientation="Horizontal"
                            Visibility="{Binding NameHasError, Converter={StaticResource BoolToVis}}"
                            Margin="0,3,0,0">
                    <TextBlock Text="! " FontWeight="Bold" FontSize="11"/>
                    <TextBlock Text="{Binding NameError}" FontSize="11"/>
                </StackPanel>
            </StackPanel>

            <TextBlock Text="Description:" FontSize="12" FontWeight="SemiBold"
                       Margin="0,0,0,3"/>
            <TextBox Text="{Binding Description, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     Padding="5,4" FontSize="12" Height="72"
                     AcceptsReturn="True" TextWrapping="Wrap"
                     VerticalScrollBarVisibility="Auto"
                     VerticalContentAlignment="Top"/>

        </StackPanel>

        <Rectangle Grid.Row="3" Fill="#E0E0E0"/>


        <StackPanel Grid.Row="4" Orientation="Horizontal"
                    HorizontalAlignment="Right" VerticalAlignment="Center"
                    Margin="0,0,16,0">
            <Button Padding="12,6" Margin="0,0,20,0" Click="AddButton_Click">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <Image Source="/Resources/Images/yes.png"
                           Width="14" Height="14" VerticalAlignment="Center"/>
                    <TextBlock Text="Add" FontSize="12"
                               Margin="6,0,0,0" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
            <Button Padding="12,6" Click="CancelButton_Click">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <Image Source="/Resources/Images/close.png"
                           Width="14" Height="14" VerticalAlignment="Center"/>
                    <TextBlock Text="Cancel" FontSize="12"
                               Margin="6,0,0,0" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
        </StackPanel>

    </Grid>
</Window>
