<Window x:Class="EventsApp.View.SearchEventWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Search Events"
        Width="580" Height="500"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="52"/>
            <RowDefinition Height="1"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="1"/>
            <RowDefinition Height="52"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal"
                    VerticalAlignment="Center" Margin="16,0">
            <Image Source="/Resources/Images/back.png"
                   Width="20" Height="20" VerticalAlignment="Center"/>
            <TextBlock Text="Search Events" FontSize="15" FontWeight="SemiBold"
                       VerticalAlignment="Center" Margin="10,0,0,0"/>
        </StackPanel>

        <Rectangle Grid.Row="1" Fill="#E0E0E0"/>

        <Grid Grid.Row="2" Margin="16,20,16,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">

                <TextBlock Text="Name:" FontSize="12" FontWeight="SemiBold"
                           Margin="0,0,0,3"/>
                <TextBox Text="{Binding Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         Padding="5,4" FontSize="12" Margin="0,0,0,10"/>

                <TextBlock Text="Event type:" FontSize="12" FontWeight="SemiBold"
                           Margin="0,0,0,3"/>
                <ComboBox ItemsSource="{Binding EventTypeItems}"
                          SelectedItem="{Binding SelectedEventType, Mode=TwoWay}"
                          DisplayMemberPath="Name"
                          Padding="5,3" FontSize="12" Margin="0,0,0,10"/>

                <TextBlock Text="Country:" FontSize="12" FontWeight="SemiBold"
                           Margin="0,0,0,3"/>
                <TextBox Text="{Binding Country, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         Padding="5,4" FontSize="12" Margin="0,0,0,10"/>

                <TextBlock Text="City:" FontSize="12" FontWeight="SemiBold"
                           Margin="0,0,0,3"/>
                <TextBox Text="{Binding City, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         Padding="5,4" FontSize="12" Margin="0,0,0,10"/>

                <TextBlock Text="Description:" FontSize="12" FontWeight="SemiBold"
                           Margin="0,0,0,3"/>
                <TextBox Text="{Binding Description, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         Padding="5,4" FontSize="12" Height="72"
                         AcceptsReturn="True" TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         VerticalContentAlignment="Top"/>

            </StackPanel>

            <StackPanel Grid.Column="2">

                <TextBlock Text="Attendance:" FontSize="12" FontWeight="SemiBold"
                           Margin="0,0,0,3"/>
                <ComboBox ItemsSource="{Binding AttendanceItems}"
                          SelectedItem="{Binding SelectedAttendance, Mode=TwoWay}"
                          DisplayMemberPath="DisplayName"
                          Padding="5,3" FontSize="12" Margin="0,0,0,10"/>

                <TextBlock Text="AvgCost (USD):" FontSize="12" FontWeight="SemiBold"
                           Margin="0,0,0,3"/>
                <TextBox Text="{Binding AvgCostText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         Padding="5,4" FontSize="12" Margin="0,0,0,10"/>

                <TextBlock Text="Is humanitarian:" FontSize="12" FontWeight="SemiBold"
                           Margin="0,0,0,6"/>
                <CheckBox IsChecked="{Binding IsHumanitarianFilter, Mode=TwoWay}"
                          FontSize="12"/>

            </StackPanel>
        </Grid>

        <Rectangle Grid.Row="3" Fill="#E0E0E0"/>

        <StackPanel Grid.Row="4" Orientation="Horizontal"
                    HorizontalAlignment="Right" VerticalAlignment="Center"
                    Margin="0,0,16,0">
            <Button Padding="12,6" Margin="0,0,20,0" Click="SearchButton_Click">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <Image Source="/Resources/Images/yes.png"
                           Width="14" Height="14" VerticalAlignment="Center"/>
                    <TextBlock Text="Search" FontSize="12"
                               Margin="6,0,0,0" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
            <Button Padding="12,6" Margin="0,0,20,0" Click="ResetButton_Click">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <Image Source="/Resources/Images/reset.png"
                           Width="14" Height="14" VerticalAlignment="Center"/>
                    <TextBlock Text="Reset" FontSize="12"
                               Margin="6,0,0,0" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
            <Button Padding="12,6" Click="CloseButton_Click">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <Image Source="/Resources/Images/close.png"
                           Width="14" Height="14" VerticalAlignment="Center"/>
                    <TextBlock Text="Close" FontSize="12"
                               Margin="6,0,0,0" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
        </StackPanel>

    </Grid>
</Window>
