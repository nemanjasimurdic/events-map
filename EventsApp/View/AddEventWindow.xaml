<Window x:Class="EventsApp.View.AddEventWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:prims="clr-namespace:System.Windows.Controls.Primitives;assembly=PresentationFramework"
        Title="Add Event"
        Width="680" Height="690"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">

    <Window.Resources>
        <Style x:Key="TouchCalendarDay"
               TargetType="{x:Type prims:CalendarDayButton}"
               BasedOn="{StaticResource {x:Type prims:CalendarDayButton}}">
            <Setter Property="Width"    Value="36"/>
            <Setter Property="Height"   Value="36"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
        <Style x:Key="TouchCalendar"
               TargetType="{x:Type Calendar}"
               BasedOn="{StaticResource {x:Type Calendar}}">
            <Setter Property="CalendarDayButtonStyle" Value="{StaticResource TouchCalendarDay}"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="52"/>
            <RowDefinition Height="1"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="1"/>
            <RowDefinition Height="52"/>
        </Grid.RowDefinitions>


        <StackPanel Grid.Row="0" Orientation="Horizontal"
                    VerticalAlignment="Center" Margin="16,0">
            <Image Source="/Resources/Images/back.png"
                   Width="20" Height="20" VerticalAlignment="Center"/>
            <TextBlock Text="Add Event Form" FontSize="15" FontWeight="SemiBold"
                       VerticalAlignment="Center" Margin="10,0,0,0"/>
        </StackPanel>

        <Rectangle Grid.Row="1" Fill="#E0E0E0"/>


        <Grid Grid.Row="2" Margin="16,20,16,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">

                <TextBlock Text="Icon (optional):" FontSize="12" FontWeight="SemiBold"
                           Margin="0,0,0,3"/>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                    <ComboBox ItemsSource="{Binding IconItems}"
                              SelectedItem="{Binding SelectedIcon, Mode=TwoWay}"
                              DisplayMemberPath="DisplayName"
                              Width="150" Padding="5,3" FontSize="12"/>
                    <Image Source="{Binding IconPreviewPath}"
                           Width="28" Height="28" Stretch="Uniform"
                           Margin="10,0,0,0" VerticalAlignment="Center"/>
                </StackPanel>

                <TextBlock Text="Event ID:" FontSize="12" FontWeight="SemiBold"
                           Margin="0,0,0,3"/>
                <StackPanel Margin="0,0,0,8">
                    <TextBox Text="{Binding EventIdText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=False}"
                             Padding="5,4" FontSize="12"/>
                    <StackPanel Orientation="Horizontal"
                                Visibility="{Binding EventIdHasError, Converter={StaticResource BoolToVis}}"
                                Margin="0,3,0,0">
                        <TextBlock Text="! " FontWeight="Bold" FontSize="11"/>
                        <TextBlock Text="{Binding EventIdError}" FontSize="11"/>
                    </StackPanel>
                </StackPanel>

                <TextBlock Text="Name:" FontSize="12" FontWeight="SemiBold"
                           Margin="0,0,0,3"/>
                <StackPanel Margin="0,0,0,8">
                    <TextBox Text="{Binding Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=False}"
                             Padding="5,4" FontSize="12"/>
                    <StackPanel Orientation="Horizontal"
                                Visibility="{Binding NameHasError, Converter={StaticResource BoolToVis}}"
                                Margin="0,3,0,0">
                        <TextBlock Text="! " FontWeight="Bold" FontSize="11"/>
                        <TextBlock Text="{Binding NameError}" FontSize="11"/>
                    </StackPanel>
                </StackPanel>

                <TextBlock Text="Description:" FontSize="12" FontWeight="SemiBold"
                           Margin="0,0,0,3"/>
                <TextBox Text="{Binding Description, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         Padding="5,4" FontSize="12" Height="72"
                         AcceptsReturn="True" TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         VerticalContentAlignment="Top"
                         Margin="0,0,0,8"/>

                <TextBlock Text="Event type name:" FontSize="12" FontWeight="SemiBold"
                           Margin="0,0,0,3"/>
                <StackPanel Margin="0,0,0,8">
                    <ComboBox ItemsSource="{Binding EventTypeItems}"
                              SelectedItem="{Binding SelectedEventType, Mode=TwoWay, ValidatesOnNotifyDataErrors=False}"
                              DisplayMemberPath="Name"
                              Padding="5,3" FontSize="12"/>
                    <StackPanel Orientation="Horizontal"
                                Visibility="{Binding EventTypeHasError, Converter={StaticResource BoolToVis}}"
                                Margin="0,3,0,0">
                        <TextBlock Text="! " FontWeight="Bold" FontSize="11"/>
                        <TextBlock Text="{Binding EventTypeError}" FontSize="11"/>
                    </StackPanel>
                </StackPanel>

                <TextBlock Text="Attendance:" FontSize="12" FontWeight="SemiBold"
                           Margin="0,0,0,3"/>
                <StackPanel Margin="0,0,0,8">
                    <ComboBox ItemsSource="{Binding AttendanceItems}"
                              SelectedItem="{Binding SelectedAttendance, Mode=TwoWay, ValidatesOnNotifyDataErrors=False}"
                              DisplayMemberPath="DisplayName"
                              Padding="5,3" FontSize="12"/>
                    <StackPanel Orientation="Horizontal"
                                Visibility="{Binding AttendanceHasError, Converter={StaticResource BoolToVis}}"
                                Margin="0,3,0,0">
                        <TextBlock Text="! " FontWeight="Bold" FontSize="11"/>
                        <TextBlock Text="{Binding AttendanceError}" FontSize="11"/>
                    </StackPanel>
                </StackPanel>

                <TextBlock Text="AvgCost (USD):" FontSize="12" FontWeight="SemiBold"
                           Margin="0,0,0,3"/>
                <StackPanel>
                    <TextBox Text="{Binding AverageCostText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=False}"
                             Padding="5,4" FontSize="12"/>
                    <StackPanel Orientation="Horizontal"
                                Visibility="{Binding AvgCostHasError, Converter={StaticResource BoolToVis}}"
                                Margin="0,3,0,0">
                        <TextBlock Text="! " FontWeight="Bold" FontSize="11"/>
                        <TextBlock Text="{Binding AvgCostError}" FontSize="11"/>
                    </StackPanel>
                </StackPanel>

            </StackPanel>


            <StackPanel Grid.Column="2">

                <TextBlock Text="Location:" FontSize="12" FontWeight="SemiBold"
                           Margin="0,0,0,3"/>
                <TextBlock Text="Country:" FontSize="11" Foreground="#555555"
                           Margin="0,0,0,2"/>
                <TextBox Text="{Binding Country, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         Padding="5,4" FontSize="12" Margin="0,0,0,4"/>
                <TextBlock Text="City:" FontSize="11" Foreground="#555555"
                           Margin="0,0,0,2"/>
                <TextBox Text="{Binding City, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         Padding="5,4" FontSize="12" Margin="0,0,0,8"/>

                <TextBlock Text="Date:" FontSize="12" FontWeight="SemiBold"
                           Margin="0,0,0,3"/>
                <DatePicker SelectedDate="{Binding CurrentYearDate, Mode=TwoWay}"
                            Height="36" FontSize="13"
                            CalendarStyle="{StaticResource TouchCalendar}"
                            Margin="0,0,0,8"/>

                <TextBlock Text="Past Dates:" FontSize="12" FontWeight="SemiBold"
                           Margin="0,0,0,3"/>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                    <DatePicker SelectedDate="{Binding PastDateToAdd, Mode=TwoWay}"
                                Width="160" Height="36" FontSize="13"
                                CalendarStyle="{StaticResource TouchCalendar}"/>
                    <Button Padding="12,6" Margin="8,0,0,0"
                            VerticalAlignment="Center"
                            Click="AddPastDate_Click">
                        <StackPanel Orientation="Horizontal">
                            <Image Source="/Resources/Images/add.png"
                                   Width="14" Height="14" VerticalAlignment="Center"/>
                            <TextBlock Text="Add" FontSize="12"
                                       Margin="6,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
                <Border BorderBrush="#CCCCCC" BorderThickness="1" CornerRadius="2"
                        Margin="0,0,0,8">
                    <ScrollViewer MaxHeight="80" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding HistoryDates}" Margin="4,2">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <DockPanel Margin="0,2">
                                        <Button DockPanel.Dock="Right"
                                                Width="32" Height="32" Padding="8"
                                                Background="Transparent" BorderThickness="0"
                                                Click="RemovePastDate_Click">
                                            <Image Source="/Resources/Images/close.png"
                                                   Width="14" Height="14" Stretch="Uniform"/>
                                        </Button>
                                        <TextBlock Text="{Binding DisplayText}"
                                                   FontSize="12" VerticalAlignment="Center"/>
                                    </DockPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Border>

                <TextBlock Text="Tags:" FontSize="12" FontWeight="SemiBold"
                           Margin="0,0,0,3"/>
                <Border BorderBrush="#CCCCCC" BorderThickness="1" CornerRadius="2"
                        Margin="0,0,0,8">
                    <ScrollViewer MaxHeight="100" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding Tags}" Margin="6,4">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                              Content="{Binding DisplayName}"
                                              FontSize="13" MinHeight="30" Margin="0,4"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Border>

                <TextBlock Text="IsHumanitarian:" FontSize="12" FontWeight="SemiBold"
                           Margin="0,0,0,3"/>
                <CheckBox IsChecked="{Binding IsHumanitarian, Mode=TwoWay}"
                          FontSize="13" MinHeight="30"/>

            </StackPanel>
        </Grid>

        <Rectangle Grid.Row="3" Fill="#E0E0E0"/>


        <StackPanel Grid.Row="4" Orientation="Horizontal"
                    HorizontalAlignment="Right" VerticalAlignment="Center"
                    Margin="0,0,16,0">
            <Button Padding="12,6" Margin="0,0,20,0" Click="AddButton_Click">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <Image Source="/Resources/Images/yes.png"
                           Width="14" Height="14" VerticalAlignment="Center"/>
                    <TextBlock Text="Add" FontSize="12"
                               Margin="6,0,0,0" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
            <Button Padding="12,6" Click="CancelButton_Click">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <Image Source="/Resources/Images/close.png"
                           Width="14" Height="14" VerticalAlignment="Center"/>
                    <TextBlock Text="Cancel" FontSize="12"
                               Margin="6,0,0,0" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
        </StackPanel>

    </Grid>
</Window>
