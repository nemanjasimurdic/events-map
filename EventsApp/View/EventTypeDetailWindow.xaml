<Window x:Class="EventsApp.View.EventTypeDetailWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Event type details"
        Width="460" Height="380"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="52"/>
            <RowDefinition Height="1"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="1"/>
            <RowDefinition Height="52"/>
        </Grid.RowDefinitions>

        <!-- ── HEADER ── -->
        <StackPanel Grid.Row="0" Orientation="Horizontal"
                    VerticalAlignment="Center" Margin="16,0">
            <Image Source="/Resources/Images/back.png"
                   Width="20" Height="20" VerticalAlignment="Center"/>
            <TextBlock Text="Event type details" FontSize="15" FontWeight="SemiBold"
                       VerticalAlignment="Center" Margin="10,0,0,0"/>
        </StackPanel>

        <Rectangle Grid.Row="1" Fill="#E0E0E0"/>

        <!-- ── CONTENT ── -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="24,20,24,20">

                <!-- Icon -->
                <Image Source="{Binding IconPath}"
                       Width="56" Height="56" Stretch="Uniform"
                       HorizontalAlignment="Left"/>

                <!-- Name (primary heading) -->
                <TextBlock Text="{Binding Name}"
                           FontSize="16" FontWeight="Bold"
                           TextWrapping="Wrap" Margin="0,12,0,0"/>

                <!-- ID (muted sub-heading) -->
                <TextBlock Text="{Binding Code, StringFormat='Type \#{0}'}"
                           FontSize="11" Foreground="#888888" Margin="0,4,0,0"/>

                <!-- Thin rule before description -->
                <Rectangle Height="1" Fill="#E8E8E8" Margin="0,14,0,14"/>

                <!-- Description -->
                <TextBlock Text="{Binding Description}"
                           FontSize="12" TextWrapping="Wrap"
                           LineHeight="19" Foreground="#333333"/>

            </StackPanel>
        </ScrollViewer>

        <Rectangle Grid.Row="3" Fill="#E0E0E0"/>

        <!-- ── FOOTER ── -->
        <Grid Grid.Row="4">
            <Button HorizontalAlignment="Right" VerticalAlignment="Center"
                    Margin="0,0,16,0" Padding="12,6"
                    Click="CloseButton_Click">
                <StackPanel Orientation="Horizontal">
                    <Image Source="/Resources/Images/close.png"
                           Width="14" Height="14" VerticalAlignment="Center"/>
                    <TextBlock Text="Close" FontSize="12"
                               Margin="6,0,0,0" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
        </Grid>
    </Grid>
</Window>
