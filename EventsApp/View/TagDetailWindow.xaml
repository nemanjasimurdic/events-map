<Window x:Class="EventsApp.View.TagDetailWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Tag details"
        Width="400" Height="340"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="52"/>
            <RowDefinition Height="1"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="1"/>
            <RowDefinition Height="52"/>
        </Grid.RowDefinitions>

        <!-- ── HEADER ── -->
        <StackPanel Grid.Row="0" Orientation="Horizontal"
                    VerticalAlignment="Center" Margin="16,0">
            <Image Source="/Resources/Images/back.png"
                   Width="20" Height="20" VerticalAlignment="Center"/>
            <TextBlock Text="Tag details" FontSize="15" FontWeight="SemiBold"
                       VerticalAlignment="Center" Margin="10,0,0,0"/>
        </StackPanel>

        <Rectangle Grid.Row="1" Fill="#E0E0E0"/>

        <!-- ── CONTENT ── -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Disabled">
            <StackPanel Margin="24,20,24,20">

                <!-- Generic tag icon (visual identity indicator) -->
                <Image Source="/Resources/Images/tag.png"
                       Width="40" Height="40" Stretch="Uniform"
                       HorizontalAlignment="Left"/>

                <!-- Description as primary heading (it IS the tag's label) -->
                <TextBlock Text="{Binding Description}"
                           FontSize="16" FontWeight="Bold"
                           TextWrapping="Wrap" Margin="0,12,0,0"/>

                <!-- ID (muted sub-heading) -->
                <TextBlock Text="{Binding Code, StringFormat='Tag \#{0}'}"
                           FontSize="11" Foreground="#888888" Margin="0,4,0,0"/>

                <!-- Thin rule -->
                <Rectangle Height="1" Fill="#E8E8E8" Margin="0,14,0,14"/>

                <!-- Color (name + hex, color-blind-friendly) -->
                <StackPanel Orientation="Horizontal">
                    <Image Source="/Resources/Images/tag.png"
                           Width="13" Height="13" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding ColorDisplay}" FontSize="12"
                               Margin="7,0,0,0" VerticalAlignment="Center"/>
                </StackPanel>

            </StackPanel>
        </ScrollViewer>

        <Rectangle Grid.Row="3" Fill="#E0E0E0"/>

        <!-- ── FOOTER ── -->
        <Grid Grid.Row="4">
            <Button HorizontalAlignment="Right" VerticalAlignment="Center"
                    Margin="0,0,16,0" Padding="12,6"
                    Click="CloseButton_Click">
                <StackPanel Orientation="Horizontal">
                    <Image Source="/Resources/Images/close.png"
                           Width="14" Height="14" VerticalAlignment="Center"/>
                    <TextBlock Text="Close" FontSize="12"
                               Margin="6,0,0,0" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
        </Grid>
    </Grid>
</Window>
